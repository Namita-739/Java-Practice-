//You are given an array arr[] and an integer target. You have to count all pairs in the array such that their sum is equal to the given target.


class Solution {
    int countPairs(int arr[], int target) {
        
        int l = arr.length;
        int c= 0;
        for(int i = 0; i<l ; i++){
             for(int j = i+1; j<l ; j++){
                 if(arr[i] + arr[j] == target)
                 c++;
             }
        }
        
        return c;
    }
}
